{
  "name": "ott-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace ott",
    "dev:web": "npm run dev --workspace ott",
    "build": "npm run build --workspace ott",
    "start": "npm run start --workspace ott",
    "lint": "npm run lint --workspace ott",
    "format": "npm run format --workspace ott",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/tw-animate-css/package.json',j=JSON.parse(fs.readFileSync(p,'utf8'));if(!j.exports['./package.json']){j.exports['./package.json']='./package.json';fs.writeFileSync(p,JSON.stringify(j,null,2))}\""
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.19"
  }
}
